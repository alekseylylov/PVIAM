<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0">
    <id>zip</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <!-- Замена properties ${nameXxxxx} в конкретных файлах, где это необходимо -->
        <fileSet>
            <directory>documentation</directory>
            <outputDirectory>documentation</outputDirectory>
            <includes>
                <include>**/syslog-deploy-ose-parameters.md</include>
                <include>**/rds-deploy-ose-parameters.md</include>
            </includes>
            <filtered>true</filtered>
        </fileSet>
        <!-- пример если НЕ захотим вносить изменения в replace_sbt_to_mycompany прямо в исходники, а сделать этапом сборки
        <fileSet>
            <directory>${build.directory}/documentation</directory>
            <outputDirectory>documentation</outputDirectory>
        </fileSet>
        -->
        <fileSet>
            <directory>documentation</directory>
            <outputDirectory>documentation</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>